# ============================================
# Code Agent 配置文件
# ============================================
#
# 使用方法:
#   1. 复制此文件为 .env
#   2. 填入你的 API Key
#   3. 根据需要修改其他配置
#
# ============================================

# ============================================
# Agent 配置
# ============================================

# 最大工具调用次数（防止无限循环，默认 20）
MAX_ITERATIONS=20

# ============================================
# 上下文管理配置（分层 Token 预算）
# ============================================
#
# 根据使用的模型调整总预算：
#   Claude 3.5 Sonnet: 200,000 tokens
#   Claude 3 Opus:     200,000 tokens
#   GPT-4o:           128,000 tokens
#   本地小模型:        32,000-128,000 tokens
#

# 总 Token 预算上限
CONTEXT_TOTAL_BUDGET=150000

# 工作记忆窗口大小（保留最近 N 轮对话）
# 轮 = 用户消息 + Assistant 回答 + 可能的工具调用
CONTEXT_WORKING_WINDOW_SIZE=10

# 工作记忆层最大 Token 数（对话历史专用）
CONTEXT_WORKING_MAX_TOKENS=50000

# 工具结果缓冲层最大 Token 数（防止大文件撑爆上下文）
CONTEXT_TOOL_BUFFER_MAX_TOKENS=80000

# 工具结果分级截断阈值（字符数）
# < 小阈值: 完整保留 / 小阈值 ~ 大阈值: 部分截断 / > 大阈值: 深度截断
# 对于大模型（Claude 3.5）可以调大阈值，保留更多完整结果
CONTEXT_TOOL_SMALL_THRESHOLD=1000
CONTEXT_TOOL_LARGE_THRESHOLD=5000

# Shell 类型（可选）
# 不设置则自动检测：Windows 用 powershell，其他用 bash
# SHELL=powershell
# SHELL=bash
# SHELL=zsh

# Bash 工具默认超时时间（秒，可选，默认 300 秒 = 5分钟）
# 对于 npm install、build 等长时间命令可以调大
BASH_TIMEOUT=300

# 激活的 LLM 提供商: claude | openai | ollama
LLM_PROVIDER=openai

# ============================================
# Claude (Anthropic) 配置
# ============================================
#
# 获取 API Key: https://console.anthropic.com/
# 模型列表: https://docs.anthropic.com/en/docs/about-claude/models
#

# 必填: 你的 Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选: 模型名称，默认 claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 可选: API 基础地址（用于代理或私有部署）
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ============================================
# OpenAI 配置
# ============================================
#
# 支持所有兼容 OpenAI 接口的服务：OpenAI、DeepSeek、通义千问等
# 只需设置对应的 OPENAI_API_KEY 和 OPENAI_BASE_URL
#

# 必填: OpenAI API Key（或兼容服务的 API Key）
OPENAI_API_KEY=

# 可选: 模型名称，默认 gpt-4o
OPENAI_MODEL=Pro/zai-org/GLM-5.1

# 可选: API 基础地址（用于兼容接口，如 DeepSeek、通义千问等）
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# ============================================
# Ollama（本地模型）配置
# ============================================
#
# 完全本地运行，无需 API Key，隐私安全
#
# 安装 Ollama: https://ollama.com/
# 下载模型: ollama pull qwen2.5:7b（或其他模型）
# 查看已下载模型: ollama list
#

# 必填: Ollama 模型名称
OLLAMA_MODEL=qwen3.5:4b

# 可选: Ollama 服务地址，默认 http://localhost:11434
OLLAMA_HOST=http://localhost:11434
