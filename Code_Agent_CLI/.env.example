# ============================================
# Code Agent 配置文件
# ============================================
#
# 使用方法:
#   1. 复制此文件为 .env
#   2. 填入你的 API Key
#   3. 根据需要修改其他配置
#
# ============================================

# ============================================
# Agent 配置
# ============================================

# 最大工具调用次数（防止无限循环，默认 20）
MAX_ITERATIONS=20

# Shell 类型（可选）
# 不设置则自动检测：Windows 用 powershell，其他用 bash
# SHELL=powershell
# SHELL=bash
# SHELL=zsh

# Bash 工具默认超时时间（秒，可选，默认 300 秒 = 5分钟）
# 对于 npm install、build 等长时间命令可以调大
BASH_TIMEOUT=300

# 激活的 LLM 提供商: claude | openai | ollama
LLM_PROVIDER=openai

# ============================================
# Claude (Anthropic) 配置
# ============================================
#
# 获取 API Key: https://console.anthropic.com/
# 模型列表: https://docs.anthropic.com/en/docs/about-claude/models
#

# 必填: 你的 Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选: 模型名称，默认 claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 可选: API 基础地址（用于代理或私有部署）
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ============================================
# OpenAI 配置
# ============================================
#
# 支持所有兼容 OpenAI 接口的服务：OpenAI、DeepSeek、通义千问等
# 只需设置对应的 OPENAI_API_KEY 和 OPENAI_BASE_URL
#

# 必填: OpenAI API Key（或兼容服务的 API Key）
OPENAI_API_KEY=

# 可选: 模型名称，默认 gpt-4o
OPENAI_MODEL=Pro/zai-org/GLM-5.1

# 可选: API 基础地址（用于兼容接口，如 DeepSeek、通义千问等）
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# ============================================
# Ollama（本地模型）配置
# ============================================
#
# 完全本地运行，无需 API Key，隐私安全
#
# 安装 Ollama: https://ollama.com/
# 下载模型: ollama pull qwen2.5:7b（或其他模型）
# 查看已下载模型: ollama list
#

# 必填: Ollama 模型名称
OLLAMA_MODEL=qwen3.5:4b

# 可选: Ollama 服务地址，默认 http://localhost:11434
OLLAMA_HOST=http://localhost:11434
