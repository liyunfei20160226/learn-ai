# 默认AI工具：claude 或 openai
# 可以通过命令行 --tool 参数覆盖
DEFAULT_TOOL=claude

# Claude Code CLI 配置（当工具为claude时使用）
CLAUDE_CMD=claude

# OpenAI API 配置（当工具为openai时使用）
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 质量检查命令（可根据项目类型配置）
# 如果留空，程序会自动探测项目语言并设置对应默认命令
# Python: ruff check . / mypy / pytest
# JavaScript/前端(React/Vue/Angular/Vite/Next.js): pnpm/yarn/npm run lint / pnpm/yarn/npm test (自动探测包管理器)
# Go: go vet ./... / go test ./...
# Java: mvn compile / mvn test
# Rust: cargo check / cargo test
# 留空自动探测：
# QUALITY_CHECK_CMD=
# TYPE_CHECK_CMD=
# TEST_CMD=
QUALITY_CHECK_CMD=
TYPE_CHECK_CMD=
TEST_CMD=

# 重试配置
MAX_RETRIES=3
MAX_FIX_ATTEMPTS=3

# Git配置
GIT_AUTO_COMMIT=true

# 输出配置
OUTPUT_BASE_DIR=./output
