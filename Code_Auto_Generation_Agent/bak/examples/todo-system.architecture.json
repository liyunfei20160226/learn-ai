{
  "project": {
    "name": "待办事项管理系统",
    "description": "轻量级待办事项管理系统 - 前后端分离架构，前端Next.js+TypeScript+Tailwind CSS，后端FastAPI，CSV文件存储",
    "type": "fullstack",
    "platform": [
      "web"
    ]
  },
  "architecture": {
    "overview": "这是一个前后端分离的待办事项管理系统。后端采用 FastAPI 框架提供 RESTful API 接口，使用 CSV 文件进行数据持久化；前端使用 Next.js 框架结合 TypeScript 和 Tailwind CSS 构建用户界面。系统通过 Docker 容器化部署，便于快速启动和运行。",
    "architecturePattern": "分层架构 (Layered Architecture)",
    "techStack": {
      "backend": {
        "language": "Python 3.12+",
        "framework": [
          "FastAPI"
        ],
        "database": "CSV File",
        "orm": "Pydantic",
        "authentication": "None"
      },
      "frontend": {
        "language": "TypeScript",
        "framework": [
          "Next.js (App Router)"
        ],
        "buildTool": "Next.js",
        "cssFramework": "Tailwind CSS"
      },
      "deployment": [
        "Docker",
        "docker-compose"
      ]
    }
  },
  "backend": {
    "directoryStructure": "backend/\n├── app/\n│   ├── __init__.py\n│   ├── main.py\n│   ├── models/\n│   │   ├── __init__.py\n│   │   └── task.py\n│   ├── services/\n│   │   ├── __init__.py\n│   │   └── csv_storage.py\n│   ├── api/\n│   │   ├── __init__.py\n│   │   ├── routes/\n│   │   │   ├── __init__.py\n│   │   │   └── tasks.py\n│   │   └── deps.py\n│   └── core/\n│       ├── __init__.py\n│       ├── config.py\n│       └── logger.py\n├── tests/\n│   ├── __init__.py\n│   ├── test_main.py\n│   ├── test_models/\n│   │   └── test_task.py\n│   ├── test_services/\n│   │   └── test_csv_storage.py\n│   └── test_api/\n│       └── test_tasks.py\n├── data/\n│   └── tasks.csv\n├── pyproject.toml\n└── uv.lock",
    "modules": [
      {
        "id": "B-MOD-001",
        "name": "核心配置模块",
        "description": "包含应用的基础配置、日志和主入口点",
        "directory": "app/core",
        "userStoryIds": [
          "US-001",
          "US-002",
          "US-007"
        ],
        "files": [
          {
            "path": "app/core/config.py",
            "description": "定义应用配置类，如数据目录路径、CSV文件名等",
            "dependencies": [
              "pydantic"
            ]
          },
          {
            "path": "app/core/logger.py",
            "description": "配置日志系统，用于记录错误和操作日志",
            "dependencies": [
              "logging"
            ]
          },
          {
            "path": "app/main.py",
            "description": "FastAPI应用实例创建和基础路由注册",
            "dependencies": [
              "fastapi",
              "app.api.routes.tasks",
              "app.core.config"
            ]
          }
        ],
        "dependencies": []
      },
      {
        "id": "B-MOD-002",
        "name": "数据模型模块",
        "description": "定义Task数据模型和相关验证逻辑",
        "directory": "app/models",
        "userStoryIds": [
          "US-001"
        ],
        "files": [
          {
            "path": "app/models/task.py",
            "description": "定义Task Pydantic模型，包含id、title、status、created_at、updated_at字段",
            "dependencies": [
              "pydantic",
              "uuid",
              "datetime"
            ]
          }
        ],
        "dependencies": []
      },
      {
        "id": "B-MOD-003",
        "name": "存储服务模块",
        "description": "实现基于CSV文件的数据读写服务",
        "directory": "app/services",
        "userStoryIds": [
          "US-002"
        ],
        "files": [
          {
            "path": "app/services/csv_storage.py",
            "description": "实现CSV文件的原子读写、初始化、备份和错误处理逻辑",
            "dependencies": [
              "csv",
              "os",
              "threading",
              "uuid",
              "app.models.task",
              "app.core.logger"
            ]
          }
        ],
        "dependencies": [
          "B-MOD-002"
        ]
      },
      {
        "id": "B-MOD-004",
        "name": "API路由模块",
        "description": "定义所有RESTful API端点及其处理逻辑",
        "directory": "app/api/routes",
        "userStoryIds": [
          "US-003",
          "US-004",
          "US-005",
          "US-006",
          "US-007"
        ],
        "files": [
          {
            "path": "app/api/routes/tasks.py",
            "description": "实现任务相关的所有API端点：GET /api/tasks, POST /api/tasks, PUT /api/tasks/{task_id}, DELETE /api/tasks/{task_id}",
            "dependencies": [
              "fastapi",
              "app.models.task",
              "app.services.csv_storage"
            ]
          }
        ],
        "dependencies": [
          "B-MOD-002",
          "B-MOD-003"
        ]
      }
    ],
    "dataModels": [
      {
        "name": "Task",
        "description": "代表一个待办事项任务",
        "tableName": "tasks.csv",
        "fields": [
          {
            "name": "id",
            "type": "UUID",
            "constraints": [
              "primary_key",
              "not_null"
            ],
            "default": "uuid.uuid4()",
            "description": "任务唯一标识符"
          },
          {
            "name": "title",
            "type": "String",
            "constraints": [
              "not_null",
              "max_length:200"
            ],
            "default": null,
            "description": "任务标题"
          },
          {
            "name": "status",
            "type": "Enum(pending, completed)",
            "constraints": [
              "not_null"
            ],
            "default": "pending",
            "description": "任务状态"
          },
          {
            "name": "created_at",
            "type": "DateTime",
            "constraints": [
              "not_null"
            ],
            "default": "datetime.utcnow()",
            "description": "任务创建时间（UTC ISO 8601格式）"
          },
          {
            "name": "updated_at",
            "type": "DateTime",
            "constraints": [
              "not_null"
            ],
            "default": "datetime.utcnow()",
            "description": "任务最后更新时间（UTC ISO 8601格式）"
          }
        ],
        "relationships": []
      }
    ],
    "apiEndpoints": [
      {
        "id": "API-001",
        "method": "GET",
        "path": "/api/tasks",
        "description": "获取所有任务列表，按创建时间倒序排列",
        "authentication": false,
        "requestBody": null,
        "responseFormat": "application/json",
        "errorResponses": [
          "400 Bad Request",
          "500 Internal Server Error"
        ]
      },
      {
        "id": "API-002",
        "method": "POST",
        "path": "/api/tasks",
        "description": "创建新任务",
        "authentication": false,
        "requestBody": "application/json {\"title\": \"string\"}",
        "responseFormat": "application/json",
        "errorResponses": [
          "400 Bad Request",
          "500 Internal Server Error"
        ]
      },
      {
        "id": "API-003",
        "method": "PUT",
        "path": "/api/tasks/{task_id}",
        "description": "更新指定任务的标题或状态",
        "authentication": false,
        "requestBody": "application/json {\"title\": \"string\", \"status\": \"pending|completed\"}",
        "responseFormat": "application/json",
        "errorResponses": [
          "400 Bad Request",
          "404 Not Found",
          "500 Internal Server Error"
        ]
      },
      {
        "id": "API-004",
        "method": "DELETE",
        "path": "/api/tasks/{task_id}",
        "description": "删除指定任务",
        "authentication": false,
        "requestBody": null,
        "responseFormat": "application/json",
        "errorResponses": [
          "404 Not Found",
          "500 Internal Server Error"
        ]
      },
      {
        "id": "API-005",
        "method": "GET",
        "path": "/health",
        "description": "健康检查接口",
        "authentication": false,
        "requestBody": null,
        "responseFormat": "application/json",
        "errorResponses": []
      }
    ],
    "dependencies": [
      {
        "name": "fastapi",
        "version": "^0.104.0",
        "description": "用于构建API的现代、快速（高性能）的web框架"
      },
      {
        "name": "uvicorn",
        "version": "^0.23.0",
        "description": "用于运行FastAPI应用的ASGI服务器"
      },
      {
        "name": "pydantic",
        "version": "^2.0.0",
        "description": "用于数据解析和验证的库"
      },
      {
        "name": "python-multipart",
        "version": "^0.0.9",
        "description": "支持表单数据解析，FastAPI文件上传依赖"
      },
      {
        "name": "httpx",
        "version": "^0.25.0",
        "description": "用于异步HTTP请求，主要用于测试"
      },
      {
        "name": "pytest",
        "version": "^7.4.0",
        "description": "测试框架"
      },
      {
        "name": "pytest-cov",
        "version": "^4.1.0",
        "description": "测试覆盖率插件"
      },
      {
        "name": "black",
        "version": "^23.7.0",
        "description": "代码格式化工具"
      },
      {
        "name": "isort",
        "version": "^5.12.0",
        "description": "导入语句排序工具"
      },
      {
        "name": "mypy",
        "version": "^1.5.0",
        "description": "静态类型检查工具"
      }
    ],
    "development": {
      "setupSteps": [
        "安装 uv 包管理器：`pip install uv`",
        "克隆项目代码",
        "进入 backend 目录",
        "运行 `uv sync` 安装所有依赖"
      ],
      "buildCommand": "uv build",
      "devCommand": "uv run uvicorn app.main:app --reload",
      "testCommand": "uv run pytest tests/ -v --cov=app/",
      "lintCommand": "uv run black . && uv run isort . && uv run mypy ."
    }
  },
