# 默认AI工具：claude 或 openai
# 可以通过命令行 --tool 参数覆盖
DEFAULT_TOOL=claude

# Claude Code CLI 配置（当工具为claude时使用）
CLAUDE_CMD=claude

# OpenAI API 配置（当工具为openai时使用）
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 是否启用质量检查
# 启用后，所有安装命令、质量检查命令、类型检查命令、测试命令
# 都完全由AI根据项目结构动态决定，不需要用户配置
QUALITY_CHECK_ENABLED=true

# 重试配置
MAX_RETRIES=3
MAX_FIX_ATTEMPTS=3

# AI 输出配置
MAX_TOKENS=32768

# Git配置
GIT_AUTO_COMMIT=true

# 输出配置
OUTPUT_BASE_DIR=./output
