{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "vitest.config.ts",
    "dist"
  ]
}
