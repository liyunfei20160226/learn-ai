# 环境变量配置示例
# 复制此文件为 .env 并填写你的配置

# OpenAI 兼容 API Key (SiliconFlow/DeepSeek/OpenAI 等)
OPENAI_API_KEY=your_api_key_here

# OpenAI API Base URL (可选，自定义代理或兼容端点)
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# 默认使用的模型
OPENAI_MODEL=Qwen/Qwen3.5-397B-A17B

# memory-mcp 服务地址（可选）
MEMORY_MCP_URL=http://localhost:8000
