{% extends "base.html.jinja" %}

{% block title %}首页 - SE Pipeline{% endblock %}

{% block content %}
<div class="min-h-screen">
    <!-- Header -->
    <nav class="backdrop-blur-md bg-white/80 sticky top-0 z-10 shadow-sm">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <div class="flex items-center">
                    <i class="fas fa-robot text-blue-600 text-2xl mr-3"></i>
                    <span class="font-bold text-xl text-gray-900">SE Pipeline</span>
                </div>
                <div class="text-sm text-gray-500">
                    软件工程多Agent流水线
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="text-center mb-12">
            <h1 class="text-4xl font-bold text-gray-900 mb-4">
                软件工程需求分析
            </h1>
            <p class="text-lg text-gray-600 max-w-3xl mx-auto">
                AI 驱动的交互式需求分析，自动澄清模糊需求，生成标准化需求规格
            </p>
        </div>

        <!-- Create New Project Card -->
        <div class="bg-white rounded-2xl shadow-xl p-8 mb-10 max-w-2xl mx-auto card-hover">
            <h2 class="text-2xl font-semibold text-gray-900 mb-6 flex items-center">
                <i class="fas fa-plus-circle text-green-500 mr-3"></i>
                创建新项目
            </h2>
            <form id="create-project-form" class="space-y-4">
                <div>
                    <label for="project_id" class="block text-sm font-medium text-gray-700 mb-2">项目 ID</label>
                    <input type="text" id="project_id" name="project_id" required
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           placeholder="只允许字母、数字、下划线、横杠"
                           onfocus="if(document.getElementById('create-error')) { document.getElementById('create-error').innerHTML = ''; }"
                    >
                </div>
                <div>
                    <label for="project_name" class="block text-sm font-medium text-gray-700 mb-2">项目名称</label>
                    <input type="text" id="project_name" name="project_name" required
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           placeholder="给项目起个名字"
                           onfocus="if(document.getElementById('create-error')) { document.getElementById('create-error').innerHTML = ''; }"
                    >
                </div>
                <div>
                    <label for="project_type" class="block text-sm font-medium text-gray-700 mb-2">项目类型</label>
                    <div id="project_type" class="space-y-2">
                        <label class="flex items-center">
                            <input type="radio" name="project_type" value="full_development" checked
                                   class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500">
                            <span class="ml-3 text-sm text-gray-700">
                                全新开发项目 - 走完整软件工程流水线（需求→架构→设计→代码→...）
                            </span>
                        </label>
                        <label class="flex items-center">
                            <input type="radio" name="project_type" value="independent_requirements"
                                   class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500">
                            <span class="ml-3 text-sm text-gray-700">
                                <strong>独立需求分析</strong> - 只做需求分析，输出标准化需求规格文档
                            </span>
                        </label>
                        <label class="flex items-center">
                            <input type="radio" name="project_type" value="code_review"
                                   class="w-4 h-4 text-blue-600 border-gray-300 focus:ring-blue-500">
                            <span class="ml-3 text-sm text-gray-700">
                                <strong>独立代码评审</strong> - 对已有本地代码目录进行评审
                            </span>
                        </label>
                    </div>
                </div>
                <div>
                    <label for="original_requirement" class="block text-sm font-medium text-gray-700 mb-2">原始需求 / 项目说明</label>
                    <textarea id="original_requirement" name="original_requirement" rows="6" required
                              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                              placeholder="请描述你的原始需求或项目说明..."
                              onfocus="if(document.getElementById('create-error')) { document.getElementById('create-error').innerHTML = ''; }"
                    ></textarea>
                </div>
                <div id="create-error"></div>
                <button type="button"
                        onclick="createProject()"
                        class="w-full bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white font-semibold py-3 px-6 rounded-lg shadow-lg transition-all duration-200 transform hover:scale-[1.02]">
                    <i class="fas fa-plus mr-2"></i>
                    创建项目
                </button>
            </form>
        </div>

        <!-- Project List -->
        <h2 class="text-2xl font-semibold text-gray-900 mb-6 flex items-center">
            <i class="fas fa-list text-blue-500 mr-3"></i>
            现有项目
        </h2>
        <div id="project-list" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for project in projects %}
            {% include "components/project_card.html.jinja" %}
            {% endfor %}
        </div>
    </div>
</div>

<!-- 删除确认模态框 -->
<div id="delete-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full mx-4 transform transition-all scale-100">
        <div class="p-6">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">
                <i class="fas fa-exclamation-triangle text-yellow-500 mr-2"></i>
                确认删除
            </h3>
            <p class="text-gray-600 mb-6" id="delete-modal-text">
                你确定要删除项目 "<span id="delete-project-name"></span>" 吗？此操作不可恢复。
            </p>
            <div class="flex justify-end space-x-3">
                <button onclick="closeDeleteModal()"
                        class="px-4 py-2 text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg font-medium transition-colors">
                    取消
                </button>
                <button onclick="confirmDelete()"
                        class="px-4 py-2 text-white bg-red-600 hover:bg-red-700 rounded-lg font-medium transition-colors">
                    <i class="fas fa-trash mr-1"></i>
                    确认删除
                </button>
            </div>
        </div>
    </div>
</div>

<script>
// 删除模态框相关
let currentDeleteProjectId = null;

function openDeleteModal(projectId, projectName) {
    currentDeleteProjectId = projectId;
    document.getElementById('delete-project-name').textContent = projectName;
    document.getElementById('delete-modal').classList.remove('hidden');
}

function closeDeleteModal() {
    currentDeleteProjectId = null;
    document.getElementById('delete-modal').classList.add('hidden');
}

function confirmDelete() {
    if (!currentDeleteProjectId) return;
    // 发送删除请求
    fetch('/projects/' + currentDeleteProjectId + '/delete', {
        method: 'POST'
    })
    .then(response => response.text())
    .then(html => {
        document.getElementById('project-list').outerHTML = html;
        closeDeleteModal();
    })
    .catch(error => {
        console.error('删除失败:', error);
        alert('删除失败，请刷新重试');
        closeDeleteModal();
    });
}

document.body.addEventListener('htmx:after-on-load', function(evt) {
    // 滚动到新项目
    const newProject = evt.detail.target.firstElementChild;
    if (newProject) {
        newProject.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
});

async function createProject() {
    const project_id = document.getElementById('project_id').value.trim();
    const project_name = document.getElementById('project_name').value.trim();
    const original_requirement = document.getElementById('original_requirement').value.trim();

    // 清除旧错误 - get the fixed placeholder always in the correct position
    const errorEl = document.getElementById('create-error');
    if (errorEl) errorEl.innerHTML = '';

    if (!project_id || !project_name || !original_requirement) {
        if (errorEl) {
            errorEl.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-lg p-4"><p class="text-red-800">请填写所有字段</p></div>';
        }
        return;
    }

    // 获取选中的项目类型
    const project_type = document.querySelector('input[name="project_type"]:checked').value;

    const response = await fetch('/projects', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            project_id: project_id,
            project_name: project_name,
            original_requirement: original_requirement,
            project_type: project_type
        })
    });

    if (response.ok) {
        // 创建成功，跳转到项目详情页
        window.location.href = '/projects/' + project_id;
    } else {
        // 创建失败，始终只在按钮上方显示一个错误
        const errorMsg = await response.text();
        if (errorEl) {
            errorEl.innerHTML = '<div class="bg-red-50 border border-red-200 rounded-lg p-4"><p class="text-red-800">' + errorMsg + '</p></div>';
        }
    }
}
</script>
{% endblock %}
