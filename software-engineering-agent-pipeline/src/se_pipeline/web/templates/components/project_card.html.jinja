<div class="bg-white rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 card-hover overflow-hidden">
    <div class="p-6">
        <div class="flex items-start justify-between mb-4">
            <div>
                <h3 class="text-lg font-semibold text-gray-900 mb-1">
                    {{ project.project_name }}
                </h3>
                <p class="text-sm text-gray-500">
                    <i class="fas fa-fingerprint mr-1"></i> {{ project.project_id }}
                </p>
            </div>
            <button class="text-red-500 hover:text-red-700 p-2 rounded-full hover:bg-red-50 transition-colors"
                    onclick="console.log('删除按钮点击: {{ project.project_id }}'); openDeleteModal('{{ project.project_id }}', '{{ project.project_name }}')"
            >
                <i class="fas fa-trash"></i>
            </button>
        </div>
        <div class="text-sm text-gray-600 mb-4 line-clamp-2">
            {% if project.original_user_requirement %}
            {{ project.original_user_requirement[:100] }}{% if project.original_user_requirement|length > 100 %}...{% endif %}
            {% else %}
            <span class="text-gray-400">无原始需求</span>
            {% endif %}
        </div>
        <div class="flex flex-wrap gap-2 mb-4">
            <span class="inline-flex items-center px-2 py-1 rounded text-xs
                {% if project.project_type == 'full_development' %}bg-gray-100 text-gray-700
                {% elif project.project_type == 'independent_requirements' %}bg-blue-100 text-blue-700
                {% elif project.project_type == 'code_review' %}bg-purple-100 text-purple-700
                {% endif %}">
                {% if project.project_type == 'full_development' %}
                完整开发
                {% elif project.project_type == 'independent_requirements' %}
                独立需求分析
                {% elif project.project_type == 'code_review' %}
                独立代码评审
                {% endif %}
            </span>
            <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-gray-100 text-gray-700">
                <i class="far fa-calendar mr-1"></i>
                {{ project.created_at.strftime('%Y-%m-%d') }}
            </span>
            <span class="inline-flex items-center px-2 py-1 rounded text-xs bg-gray-100 text-gray-700 ml-auto">
                {{ '已完成' if project.requirements_spec or project.codereview_report else '进行中' }}
            </span>
        </div>
        <a href="/projects/{{ project.project_id }}"
           class="block w-full text-center bg-gray-50 hover:bg-gray-100 text-gray-700 font-medium py-2 px-4 rounded-lg transition-colors">
            <i class="fas fa-external-link-alt mr-1"></i>
            打开项目
        </a>
    </div>
</div>
