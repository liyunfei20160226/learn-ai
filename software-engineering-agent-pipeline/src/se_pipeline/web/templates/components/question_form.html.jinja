<div class="bg-white rounded-2xl shadow-xl p-6 mb-8 border-l-4 border-blue-500">
    <h2 class="text-xl font-semibold text-gray-900 mb-6">
        <i class="fas fa-question-circle text-blue-500 mr-2"></i>
        需要你回答以下问题
    </h2>
    <form id="answer-form" hx-post="/projects/{{ state.project_id }}/answer"
          hx-target="#progress-container"
          hx-swap="innerHTML"
          class="space-y-6">
        {% for question in unanswered %}
        <div class="bg-blue-50 rounded-lg p-4">
            <label class="block text-base font-medium text-gray-800 mb-3">
                <span class="text-blue-600 font-bold">Q{{ loop.index }}.</span>
                {{ question.question }}
            </label>
            <textarea id="answer-{{ loop.index }}"
                      name="answer-{{ loop.index }}"
                      rows="3"
                      class="w-full px-4 py-2 border border-blue-200 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white"
                      placeholder="请输入你的回答..."
                      required></textarea>
        </div>
        {% endfor %}
        <button id="submit-answer-btn"
                type="submit"
                class="w-full bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:-to-indigo-700 text-white font-semibold py-3 px-8 rounded-lg shadow-lg transition-all duration-200 transform hover:scale-[1.02]">
            <i class="fas fa-paper-plane mr-2"></i>
            提交回答，继续分析
        </button>
    </form>
    <script>
    // htmx:before-request 事件：HTMX 已经收集完数据，现在可以安全禁用
    document.getElementById('answer-form').addEventListener('htmx:before-request', function() {
        // 禁用开始分析按钮
        const startBtn = document.getElementById('start-btn');
        if (startBtn) {
            startBtn.disabled = true;
            startBtn.classList.add('opacity-50');
            startBtn.classList.add('cursor-not-allowed');
        }
        // 禁用所有输入框（此时数据已经发送，禁用不影响）
        document.querySelectorAll('textarea').forEach(el => {
            el.disabled = true;
            el.classList.add('opacity-50');
            el.classList.add('cursor-not-allowed');
        });
        // 禁用提交按钮
        const submitBtn = document.getElementById('submit-answer-btn');
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-50');
            submitBtn.classList.add('cursor-not-allowed');
        }
        // 半透明整个容器
        const container = document.getElementById('questions-container');
        if (container) {
            container.classList.add('opacity-50');
            container.classList.add('cursor-not-allowed');
        }
    });
    </script>
</div>
