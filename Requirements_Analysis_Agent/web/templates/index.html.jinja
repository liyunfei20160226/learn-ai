<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AutoPRD - 全自动PRD生成Agent</title>
    <link rel="icon" type="image/svg+xml" href="/static/favicon.svg">
    <link rel="stylesheet" href="/static/style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>AutoPRD</h1>
            <p class="subtitle">全自动需求文档生成Agent</p>
        </header>

        <main>
            <section class="form-section">
                <form id="generator-form">
                    <div class="form-group">
                        <label for="requirement">需求描述 <span class="required">*</span></label>
                        <textarea id="requirement" name="requirement" rows="4" placeholder="请输入你的需求描述，例如：开发一个票据管理系统..." required></textarea>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="tool">AI工具</label>
                            <select id="tool" name="tool">
                                <option value="openai" selected>OpenAI</option>
                                <option value="claude">Claude (CLI)</option>
                                <option value="amp">Anthropic CLI (amp)</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="mode">运行模式</label>
                            <select id="mode" name="mode">
                                <option value="auto" selected>全自动</option>
                                <option value="interactive">交互式问答</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label for="max_iterations">最大迭代次数</label>
                            <input type="number" id="max_iterations" name="max_iterations" value="10" min="1" max="50">
                        </div>

                        <div class="form-group">
                            <label for="rag_topk">RAG检索片段数</label>
                            <input type="number" id="rag_topk" name="rag_topk" value="5" min="1" max="20">
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group" style="flex: 1;">
                            <label for="output_name">输出目录名称 <span class="optional">(可选)</span></label>
                            <input type="text" id="output_name" name="output_name" placeholder="留空自动生成，例如：ticket-system">
                            <p class="hint">自定义目录名称，方便识别查找生成的文件</p>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="background_dir">背景资料目录（可选）</label>
                        <input type="text" id="background_dir" name="background_dir" placeholder="./docs 或 C:\project\documents">
                        <p class="hint">输入本地项目资料目录路径，将递归加载包括子目录下的所有支持文档（PDF、Word、Excel、PowerPoint、文本、Markdown）</p>
                    </div>

                    <div class="form-actions">
                        <button type="submit" id="start-btn" class="btn btn-primary">开始生成</button>
                    </div>
                </form>
            </section>

            <section class="log-section">
                <h2>运行日志 <span id="elapsed-time" class="elapsed-time" style="display: none;">已运行: <span id="elapsed-value">00:00</span></span></h2>
                <div id="log-container" class="log-container"></div>
            </section>

            <section class="result-section" id="result-section" style="display: none;">
                <h2>生成结果</h2>
                <div id="result-files" class="result-files"></div>
            </section>
        </main>

        <footer>
            <p>AutoPRD - Automatic PRD Generation Agent</p>
        </footer>
    </div>

    <script src="/static/script.js"></script>
</body>
</html>
